  "keyFeatures": [
    "File uploads with support for any file type",
    "Folder organization and tags",
    "URL shortening service",
    "Multiple authentication methods (OAuth2, 2FA, Passkeys)",
    "Image compression and video thumbnails",
    "Discord and HTTP webhooks",
    "Custom embeds for shared files",
    "S3 and local storage support",
    "User quotas and invites",
    "Custom themes and branding",
    "ShareX integration",
    "Progressive Web App (PWA)",
    "Partial/chunked uploads",
    "Admin dashboard with metrics"
  ],
  "publicApiSurface": [
    "POST /api/upload - Upload files",
    "POST /api/upload/partial - Chunked uploads",
    "GET /api/user/files - List user files",
    "POST /api/user/folders - Create folder",
    "POST /api/user/urls - Create short URL",
    "POST /api/auth/login - User login",
    "POST /api/auth/register - User registration",
    "GET /api/stats - Server statistics",
    "GET /api/user - Get user profile",
    "DELETE /api/user/files/:id - Delete file",
    "PATCH /api/user/files/:id - Update file",
    "POST /api/user/mfa/totp - Enable 2FA",
    "POST /api/user/mfa/passkey - Register passkey",
    "GET /api/users - Admin: list users",
    "GET /api/server/settings - Get server settings",
    "ziplinectl read-config - CLI config export",
    "ziplinectl list-users - CLI user management",
    "ziplinectl set-user - CLI user modification",
    "ziplinectl import-dir - CLI bulk import"
  ]
